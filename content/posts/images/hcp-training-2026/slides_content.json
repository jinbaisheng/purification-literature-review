  {
    "slide_number": 5,
    "title": "各检测方法优缺点对比",
    "content": [
      {
        "type": "text",
        "text": "各检测方法优缺点对比",
        "level": 0,
        "is_bullet": false
      },
      {
        "type": "text",
        "text": "企业通常采用ELISA进行常规监控，而用MS识别“持久性”和“高风险”HCP",
        "level": 0,
        "is_bullet": true
      }
    ],
    "tables": [
      {
        "rows": [
          [
            "检测方法",
            "核心优点",
            "核心缺点",
            "检出限 (LOD)"
          ],
          [
            "ELISA",
            "操作简便、灵敏度高、高通量、行业标准",
            "无法识别种类、依赖特定抗体、抗体覆盖度（Coverage）有限",
            "~1 ppm "
          ],
          [
            "LC-MS/MS",
            "可定量且定性、无需预先制备抗体、能识别特定高风险蛋白",
            "仪器昂贵、数据分析复杂、动态范围有限（受主成分抗体干扰）",
            "1 - 50 ppm"
          ],
          [
            "2D-GE",
            "可视化蛋白分布、直观展示抗体覆盖度",
            "耗时费力、通量低、对低丰度蛋白不敏感",
            "μg 级"
          ]
        ],
        "row_count": 4,
        "col_count": 4
      }
    ],
    "images": []
